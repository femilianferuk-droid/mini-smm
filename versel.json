// vercel.json
{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval' https://telegram.org; connect-src *; img-src * data: blob:; style-src * 'unsafe-inline'; frame-ancestors https://web.telegram.org https://telegram.org;" }
      ]
    }
  ]
}
